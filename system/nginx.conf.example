# ============================================================================
# Nginx Reverse Proxy — RNF-SEG-01 (Cifrado en Tránsito)
# Adaptado del nginx.conf.example de Django para Node.js
# ============================================================================

# Redirección HTTP → HTTPS
server {
    listen 80;
    server_name midominio.cl www.midominio.cl;

    # Redirección de todo HTTP a HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name midominio.cl www.midominio.cl;

    # Certificados Let's Encrypt (Certbot)
    ssl_certificate /etc/letsencrypt/live/midominio.cl/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/midominio.cl/privkey.pem;

    # Seguridad SSL/TLS robusta (Evita ataques comunes)
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers "ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384";
    
    # HSTS (Obliga al cliente a usar siempre HTTPS)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    
    # Cabeceras de Seguridad recomendadas (equivalente a Django SecurityMiddleware)
    add_header X-Frame-Options DENY;            # Previene Clickjacking
    add_header X-Content-Type-Options nosniff;
    add_header X-XSS-Protection "1; mode=block";

    # ==========================================
    # Proxy a Node.js (reemplaza Gunicorn :8000)
    # ==========================================
    location / {
        proxy_pass http://app:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        
        # Le dice a Node.js que la petición original venía por HTTPS
        proxy_set_header X-Forwarded-Proto https;

        # WebSocket support (para Vite HMR en desarrollo)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # ==========================================
    # Swagger docs (acceso directo)
    # ==========================================
    location /api/docs {
        proxy_pass http://app:3000/api/docs;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}

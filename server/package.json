{
  "name": "uct-vinculo-mayor-server",
  "version": "1.0.0",
  "description": "Backend API para UCT-Vínculo Mayor - Plataforma de Voluntariado",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:seed": "node prisma/seed.js",
    "prisma:studio": "npx prisma studio",
    "test": "jest --coverage --coverageReporters=text --coverageReporters=lcov --coverageReporters=cobertura",
    "test:ci": "jest --coverage --coverageReporters=lcov --coverageReporters=cobertura --ci",
    "test:unit": "jest tests/unit --coverage --coverageReporters=text",
    "test:integration": "jest tests/integration --coverage --coverageReporters=text"
  },
  "keywords": [
    "uct",
    "voluntariado",
    "adulto-mayor"
  ],
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "prisma": "^6.9.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/app.js",
      "!src/infrastructure/swagger.js"
    ],
    "coverageThreshold": {
      "./src/domain/entities/": {
        "lines": 90,
        "functions": 90,
        "branches": 90,
        "statements": 90
      },
      "./src/domain/services/": {
        "lines": 90,
        "functions": 90,
        "branches": 85,
        "statements": 90
      }
    },
    "coverageDirectory": "coverage"
  }
}

# ============================================================================
# Variables de Entorno — UCT-Vínculo Mayor
# Copia este archivo como .env y ajusta los valores
# ============================================================================

# Entorno (development o production)
NODE_ENV=development

# Base de Datos PostgreSQL
DATABASE_URL="postgresql://postgres:tu_password@localhost:5432/uct_vinculo_mayor?schema=public"

# JWT (Autenticación)
JWT_SECRET="tu-clave-super-secreta-aqui"
JWT_EXPIRES_IN="24h"

# Servidor
PORT=3000

# CORS (Frontend)
CORS_ORIGIN="http://localhost:5173"

# Redis (Cache — RNF-REN-01)
REDIS_URL="redis://127.0.0.1:6379"
